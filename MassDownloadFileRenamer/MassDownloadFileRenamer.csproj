		<OutputType>Exe</OutputType>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<Platforms>x64</Platforms>
		<RootNamespace>DoenaSoft.MassDownloadFileRenamer</RootNamespace>
