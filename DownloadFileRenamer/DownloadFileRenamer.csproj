<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net472</TargetFramework>
		<OutputType>WinExe</OutputType>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<Platforms>x64</Platforms>
		<RootNamespace>DoenaSoft.DownloadRenamer</RootNamespace>
		<AssemblyName>DownloadRenamer</AssemblyName>
		<UseWindowsForms>true</UseWindowsForms>
		<ApplicationIcon>djdsoft.ico</ApplicationIcon>
	</PropertyGroup>

	<ItemGroup>
		<Content Include="djdsoft.ico" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\DownloadFileRenamerLib\DownloadFileRenamerLib.csproj" />
	</ItemGroup>

	<ItemGroup>
		<Reference Include="System.Web" />
	</ItemGroup>

</Project>