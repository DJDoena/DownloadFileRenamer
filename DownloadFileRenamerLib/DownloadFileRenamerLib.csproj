<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net472</TargetFramework>
		<OutputType>Library</OutputType>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<Platforms>x64</Platforms>
		<RootNamespace>DoenaSoft.DownloadRenamer</RootNamespace>
		<AssemblyName>DownloadFileRenamerLib</AssemblyName>
		<Version>$([System.DateTime]::Now.ToString("yyyy.MM.dd.HHmm"))</Version>
		<FileVersion>$([System.DateTime]::Now.ToString("yyyy.MM.dd.HHmm"))</FileVersion>
	</PropertyGroup>

	<ItemGroup>
		<Compile Include="..\..\CopySeries\CopySeries\CopySeriesLib\DateShows.cs">
			<Link>DateShows.cs</Link>
		</Compile>
		<Compile Include="..\..\CopySeries\CopySeries\CopySeriesLib\Names.cs">
			<Link>Names.cs</Link>
		</Compile>
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="DoenaSoft.ToolBox">
			<Version>2.0.0</Version>
		</PackageReference>
	</ItemGroup>

	<ItemGroup>
		<Reference Include="System.Web" />
	</ItemGroup>

</Project>